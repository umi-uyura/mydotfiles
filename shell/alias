#!/usr/bin/env bash
## -*- mode: sh-mode; coding: utf-8 -*-

if [ "$(uname)" = "Linux" ]; then
  OS="LINUX"
elif [ "$(uname)" = "Darwin" ]; then
  OS="MACOS"
fi

#
# alias
#

alias passgen='pwgen -cnysB1 18 8'
alias passgen2='pwgen -cnsB1 18 8'

if [ "$OS" == "MACOS" ]; then
  alias mdview='open -a mdview'
fi

# pnpm dlx aliases (@latest で常に最新バージョンをチェック)
alias ccusage='pnpm dlx ccusage@latest'
alias gemini='@google/gemini-cli@latest'
alias openspec='pnpm dlx @fission-ai/openspec@latest'
alias ncu='pnpm dlx npm-check-updates@latest'
alias tldr='pnpm dlx tldr@latest'
alias 'react-doctor'='pnpm dlx react-doctor@latest'
