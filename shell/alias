#!/usr/bin/env bash
## -*- mode: sh-mode; coding: utf-8 -*-

if [ "$(uname)" = "Linux" ]; then
  OS="LINUX"
elif [ "$(uname)" = "Darwin" ]; then
  OS="MACOS"
fi

#
# alias
#

alias passgen='pwgen -cnysB1 18 8'
alias passgen2='pwgen -cnsB1 18 8'

if [ "$OS" == "MACOS" ]; then
  alias mdview='open -a mdview'
fi

# pnpm dlx aliases
alias openspec='pnpm dlx @fission-ai/openspec'
alias ccusage='pnpm dlx ccusage'
alias ncu='pnpm dlx npm-check-updates'
alias tldr='pnpm dlx tldr'
